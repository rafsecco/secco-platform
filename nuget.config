<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Feed privado da plataforma (ADR-0011) -->
    <add key="secco" value="https://nuget.pkg.github.com/rafsecco/index.json" />
  </packageSources>
  <!-- Segurança de supply chain: pacotes Secco.* só podem vir do feed privado. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="secco">
      <package pattern="Secco.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
