<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Feed privado (ADR-0011) — descomentar quando o repositório GitHub existir:
    <add key="secco" value="https://nuget.pkg.github.com/SEU_USUARIO/index.json" />
    -->
  </packageSources>
  <!-- Segurança de supply chain: pacotes Secco.* só podem vir do feed privado.
       Ativar junto com o feed acima:
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="secco">
      <package pattern="Secco.*" />
    </packageSource>
  </packageSourceMapping>
  -->
</configuration>
