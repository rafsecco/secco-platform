        "required": [
          "id",
          "name",
          "slug",
          "isActive",
          "createdAt",
          "products"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
