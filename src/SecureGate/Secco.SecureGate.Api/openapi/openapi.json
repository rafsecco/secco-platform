            "type": "string"
          }
        }
      },
      "CreateRoleRequest": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateTenantRequest": {
        "required": [
          "name",
          "slug"
