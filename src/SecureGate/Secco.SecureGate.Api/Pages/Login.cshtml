@page
@model LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Entrar — Secco SecureGate</title>
    <style>
        :root { color-scheme: light dark; }
        * { box-sizing: border-box; }
        body {
            margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center;
            font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
            background: #f4f5f7; color: #1b1f24;
        }
        .card {
            width: 100%; max-width: 360px; margin: 1rem; padding: 2rem;
            background: #fff; border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,.08);
        }
        h1 { font-size: 1.25rem; margin: 0 0 .25rem; }
        p.sub { margin: 0 0 1.5rem; color: #6b7280; font-size: .875rem; }
        label { display: block; font-size: .8125rem; font-weight: 600; margin: .75rem 0 .25rem; }
        input[type=email], input[type=password] {
            width: 100%; padding: .625rem .75rem; font-size: .9375rem;
            border: 1px solid #d1d5db; border-radius: 8px; background: #fff; color: inherit;
        }
        input:focus { outline: 2px solid #2563eb; outline-offset: 1px; border-color: #2563eb; }
        button {
            width: 100%; margin-top: 1.25rem; padding: .625rem; font-size: .9375rem; font-weight: 600;
            color: #fff; background: #2563eb; border: 0; border-radius: 8px; cursor: pointer;
        }
        button:hover { background: #1d4ed8; }
        .error { margin-top: 1rem; padding: .625rem .75rem; border-radius: 8px;
            background: #fef2f2; color: #b91c1c; font-size: .8125rem; border: 1px solid #fecaca; }
        .field-error { color: #b91c1c; font-size: .75rem; margin-top: .25rem; display: block; }
        @@media (prefers-color-scheme: dark) {
            body { background: #0f1115; color: #e5e7eb; }
            .card { background: #1a1d23; box-shadow: 0 8px 30px rgba(0,0,0,.4); }
            p.sub { color: #9ca3af; }
            input[type=email], input[type=password] { background: #0f1115; border-color: #374151; }
            .error { background: #2a1416; color: #fca5a5; border-color: #7f1d1d; }
        }
    </style>
</head>
<body>
    <main class="card">
        <h1>Secco SecureGate</h1>
        <p class="sub">Entre com suas credenciais para continuar.</p>

        <form method="post" asp-route-returnUrl="@Model.ReturnUrl" novalidate>
            <label asp-for="Input.Email">E-mail</label>
            <input asp-for="Input.Email" type="email" autocomplete="username" autofocus />
            <span class="field-error" asp-validation-for="Input.Email"></span>

            <label asp-for="Input.Password">Senha</label>
            <input asp-for="Input.Password" type="password" autocomplete="current-password" />
            <span class="field-error" asp-validation-for="Input.Password"></span>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error" role="alert">@Model.ErrorMessage</div>
            }

            <button type="submit">Entrar</button>
        </form>
    </main>
</body>
</html>
